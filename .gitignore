# Godot 4 — auto-generated files (never commit these)
.godot/

# Godot import metadata (regenerated per machine)
*.import

# Godot export presets (contains platform-specific paths)
export_presets.cfg

# Mono/C# build artifacts (not using C# but just in case)
.mono/
data_*/
mono_crash.*.json

